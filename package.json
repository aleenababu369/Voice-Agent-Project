{
  "name": "multilingual-voice-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Low-latency multilingual AI voice agent for education and healthcare.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "nodemon",
    "dev:api:once": "node --env-file-if-exists=.env --experimental-strip-types apps/api/src/index.ts",
    "dev:admin": "npm --prefix apps/admin run dev",
    "build:admin": "npm --prefix apps/admin run build",
    "check": "node scripts/check-workspace.mjs",
    "smoke:api": "node --env-file-if-exists=.env --experimental-strip-types scripts/smoke-api.ts"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "nodemon": "^3.1.14",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
