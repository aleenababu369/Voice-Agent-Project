PORT=5005
APP_ENV=development
DEFAULT_DOMAIN=education
DEFAULT_LANGUAGE=en-IN

# MongoDB — the application database. Leave unset to run fully in-memory.
# Atlas example: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>
MONGODB_URI=
MONGODB_DB=voice_agent

# Auth: secret used to sign session JWTs. Set a strong value in production.
JWT_SECRET=change-me-in-production
# Set to "true" to require a valid login token on all non-public routes.
AUTH_ENFORCE=false

# Real LLM (OpenAI-compatible). Leave unset to use the built-in zero-cost rule engine.
# Examples: OpenAI -> https://api.openai.com/v1 ; local Ollama -> http://localhost:11434/v1
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_MS=8000

# Uncertainty-aware dialogue management. Each collected value gets a belief = ASR confidence x NLU confidence.
# >= ACCEPT  -> accept the value silently (implicit read-back).
# >= CONFIRM -> ask the caller to confirm it ("did you say X?").
# <  CONFIRM -> reject and re-prompt for that field.
# MAX_ATTEMPTS caps how many times one field is asked before accepting the best value (avoids loops).
UADM_ACCEPT_THRESHOLD=0.7
UADM_CONFIRM_THRESHOLD=0.4
UADM_MAX_ATTEMPTS=3
