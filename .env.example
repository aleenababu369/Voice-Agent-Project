PORT=5005
APP_ENV=development
DEFAULT_DOMAIN=education
DEFAULT_LANGUAGE=en-IN
DATABASE_URL=postgresql://voice_agent:voice_agent@localhost:5432/voice_agent
REDIS_URL=redis://localhost:6379
TELEPHONY_PROVIDER=sip
ASR_PROVIDER=faster-whisper
TTS_PROVIDER=coqui

# Auth: secret used to sign session JWTs. Set a strong value in production.
JWT_SECRET=change-me-in-production
# Set to "true" to require a valid login token on all non-public routes.
AUTH_ENFORCE=false

# Real LLM (OpenAI-compatible). Leave unset to use the built-in zero-cost rule engine.
# Examples: OpenAI -> https://api.openai.com/v1 ; local Ollama -> http://localhost:11434/v1
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_MS=8000
