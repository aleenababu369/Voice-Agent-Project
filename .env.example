PORT=5005
APP_ENV=development
DEFAULT_DOMAIN=education
DEFAULT_LANGUAGE=en-IN

# MongoDB — the application database. Leave unset to run fully in-memory.
# Atlas example: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>
MONGODB_URI=
MONGODB_DB=voice_agent

# Auth: secret used to sign session JWTs. Set a strong value in production.
JWT_SECRET=change-me-in-production
# Set to "true" to require a valid login token on all non-public routes.
AUTH_ENFORCE=false

# Real LLM (OpenAI-compatible). Leave unset to use the built-in zero-cost rule engine.
# Examples: OpenAI -> https://api.openai.com/v1 ; local Ollama -> http://localhost:11434/v1
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_MS=8000
LLM_TURN_ATTEMPTS=3
LLM_KEEP_ALIVE=10m
LLM_KEEP_WARM_INTERVAL_MS=60000

# Speech recognition (ASR). Leave unset to use the browser's built-in Web Speech recognizer.
# Set these to use a local Whisper server (OpenAI-compatible) for far better accuracy on accented/multilingual speech.
# Easy local server (Docker): speaches -> docker run -d -p 8000:8000 ghcr.io/speaches-ai/speaches:latest-cpu
#   then WHISPER_BASE_URL=http://localhost:8000/v1 and WHISPER_MODEL=Systran/faster-whisper-small
WHISPER_BASE_URL=
WHISPER_API_KEY=
WHISPER_MODEL=
WHISPER_TIMEOUT_MS=15000
# Leave unset/false so Whisper AUTO-DETECTS each utterance's language (enables in-call language switching).
# Set true to force every clip to the call's current language (more accurate if the call is always one language).
WHISPER_FORCE_LANGUAGE=false

# Uncertainty-aware dialogue management. Each collected value gets a belief = ASR confidence x NLU confidence.
# >= ACCEPT  -> accept the value silently (implicit read-back).
# >= CONFIRM -> ask the caller to confirm it ("did you say X?").
# <  CONFIRM -> reject and re-prompt for that field.
# MAX_ATTEMPTS caps how many times one field is asked before accepting the best value (avoids loops).
UADM_ACCEPT_THRESHOLD=0.6
UADM_CONFIRM_THRESHOLD=0.4
UADM_MAX_ATTEMPTS=3
